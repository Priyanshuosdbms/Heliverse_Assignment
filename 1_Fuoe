addrmap my_i2c_controller {
    // 1. Define the build-time parameter
    param bit IC_ULTRA_FAST_MODE = 0;

    reg spike_suppression_limit_reg {
        name = "I2C SS, FS or FM+ Spike Suppression Limit";
        
        // 2. Use the parameter to conditionally include the field
        if (IC_ULTRA_FAST_MODE == 0) {
            field {
                name = "IC_FS_SPKLEN";
                desc = "This register must be set before any I2C...";
            } IC_FS_SPKLEN[7:0] = 0x0;
        }

        field {
            name = "RSVD_IC_FS_SPKLEN";
            desc = "Reserved - Read Only";
        } RSVD_IC_FS_SPKLEN[31:8];
    };

    // Instantiate the register
    spike_suppression_limit_reg IC_FS_SPKLEN_REG @ 0x0;
};
