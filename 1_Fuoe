
import pdfplumber
import json
import re

def extract_with_metadata(pdf_path):
    structured_data = []

    with pdfplumber.open(pdf_path) as pdf:
        for i, page in enumerate(pdf.pages):
            # 1. Find all tables on the page
            tables = page.find_tables()
            
            for j, table in enumerate(tables):
                # Get coordinates of the table: (x0, top, x1, bottom)
                table_bbox = table.bbox
                table_top = table_bbox[1]
                
                # 2. Define a "Metadata Search Area" 
                # We look 100 pixels above the table for the title/context
                search_area = (0, max(0, table_top - 100), page.width, table_top)
                context_zone = page.crop(search_area)
                
                # Extract text above the table and clean it
                raw_text = context_zone.extract_text()
                lines = [line.strip() for line in raw_text.split('\n') if line.strip()] if raw_text else []
                
                # Assume the last line before the table is the Title/Caption
                table_name = lines[-1] if lines else f"Table_{i+1}_{j+1}"
                preceding_context = " ".join(lines[:-1]) if len(lines) > 1 else ""

                # 3. Extract actual table data
                table_content = table.extract()
                
                # Handle empty tables
                if not table_content:
                    continue

                # 4. Construct the JSON entry
                entry = {
                    "id": f"pg{i+1}_tbl{j+1}",
                    "table_name": table_name,
                    "page": i + 1,
                    "metadata": {
                        "context": preceding_context,
                        "location": table_bbox,
                        "rows": len(table_content),
                        "cols": len(table_content[0])
                    },
                    "header": table_content[0],
                    "rows": table_content[1:]
                }
                structured_data.append(entry)

    return structured_data

# --- Execution ---
pdf_file = "your_document.pdf"
results = extract_with_metadata(pdf_file)

# Save to JSON file
with open("extracted_tables.json", "w") as f:
    json.dump(results, f, indent=4)

print(f"Successfully extracted {len(results)} tables to JSON.")
